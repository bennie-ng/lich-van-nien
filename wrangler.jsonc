// Cloudflare Workers config — static-assets deploy of the web app.
// The dashboard's Git integration runs `npm run build` (which exports the
// Expo web app to apps/mobile/dist) and then `npx wrangler deploy`.
{
  "name": "astrologik",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./apps/mobile/dist",
    "not_found_handling": "single-page-application"
  }
}
